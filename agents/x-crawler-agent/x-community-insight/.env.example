# Browser profile directory (for logged-in sessions)
BROWSER_PROFILE_DIR=./data/browser-profile

# Max concurrent crawl jobs
MAX_CONCURRENT_JOBS=1

# Default wait time between actions (ms)
MIN_WAIT_MS=3000
MAX_WAIT_MS=8000

# Max scroll rounds before stopping (no new content)
MAX_EMPTY_ROUNDS=3

# Default max posts per account crawl
DEFAULT_MAX_POSTS=100

# Default max replies per post crawl
DEFAULT_MAX_REPLIES=500

# Default crawl passes for completeness
DEFAULT_CRAWL_PASSES=3

# Analysis provider: local | openai | claude
ANALYSIS_PROVIDER=local

# OpenAI API Key (optional, for AI analysis)
# OPENAI_API_KEY=

# Database path
DATABASE_PATH=./data/database.sqlite
