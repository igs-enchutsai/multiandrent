# GIF Finder Agent Environment Variables

# Tenor API (Recommended - optimized for chat/messaging)
# Get your key from: https://developers.google.com/tenor
TENOR_API_KEY=

# GIPHY API (Alternative - broader GIF selection)  
# Get your key from: https://developers.giphy.com/
GIPHY_API_KEY=

# Default GIF provider (tenor or giphy)
GIF_PROVIDER=tenor

# HoYeah API for web search fallback (if available)
HOYEAH_API_BASE=
HOYEAH_API_KEY=
